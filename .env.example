# Template variabili d'ambiente
# Copia questo file come .env e compila i valori reali
# NON committare mai il file .env nel repository

# Applicazione
APP_NAME=NomeProgetto
APP_ENV=development
APP_PORT=3000
APP_SECRET_KEY=cambia-con-valore-sicuro

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nome_database
DB_USER=utente_db
DB_PASSWORD=password_db

# API esterne (aggiungi le chiavi necessarie al progetto)
# API_KEY_SERVIZIO=

# Debug
DEBUG=true
LOG_LEVEL=info
